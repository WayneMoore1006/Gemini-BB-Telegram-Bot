# Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Binance API Settings
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
# Use 'true' for testnet, 'false' for production
USE_TESTNET=true

# Strategy Settings
DEFAULT_SYMBOL=BTCUSDT
# 支持多週期，以逗號分隔：15m, 1h, 4h, 1d...
INTERVALS=15m,1h,4h,1d
BB_LENGTH=20
BB_STD_MULTIPLIER=2.0

# Price Level Settings (整數關口警報)
PRICE_LEVEL_STEP=1000
ENABLE_PRICE_LEVEL_ALERTS=true

# Trading Settings
ENABLE_LIVE_TRADING=false
PAPER_TRADING=true

# AI Service Settings (Google Gemini)
# Options: mock, gemini
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# System Settings
LOG_LEVEL=info
